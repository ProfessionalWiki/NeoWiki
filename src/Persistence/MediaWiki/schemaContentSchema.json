{
	"$schema": "https://json-schema.org/draft/2020-12/schema#",
	"type": "object",
	"properties": {
		"description": {
			"type": "string"
		},
		"propertyDefinitions": {
			"type": "object",
			"patternProperties": {
				"^.*$": {
					"type": "object",
					"additionalProperties": true,
					"required": [
						"type"
					],
					"properties": {
						"description": {
							"type": "string"
						},
						"type": {
							"type": "string",
							"minLength": 1
						},
						"required": {
							"type": "boolean"
						},
						"multiple": {
							"type": "boolean"
						},
						"uniqueItems": {
							"type": "boolean"
						}
					},
					"allOf": [
						{
							"if": {
								"required": [
									"type"
								],
								"properties": {
									"type": {
										"const": "relation"
									}
								}
							},
							"then": {
								"required": [
									"relation",
									"targetSchema"
								],
								"properties": {
									"relation": {
										"type": "string",
										"pattern": "^\\S(.*\\S)?$",
										"$error": "The relation type must not be empty or have surrounding whitespace."
									},
									"targetSchema": {
										"type": "string",
										"pattern": "^\\S(.*\\S)?$",
										"$error": "The target schema must not be empty or have surrounding whitespace."
									}
								}
							}
						}
					]
				}
			}
		}
	},
	"required": [
		"propertyDefinitions"
	],
	"additionalProperties": true
}
