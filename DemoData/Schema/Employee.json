{
	"description": "Someone working for a company",
	"propertyDefinitions": {
		"LegalName": {
			"type": "text"
		},
		"WorkEmail": {
			"type": "text"
		},
		"EmploymentFte": {
			"type": "number",
			"constraints": {
				"minimum": 0,
				"maximum": 100
			},
			"default": 100
		},
		"Skills": {
			"type": "text",
			"constraints": {
				"multiple": true,
				"uniqueItems": true
			},
			"description": "A list of the person's skills"
		},
		"Employer": {
			"type": "relation",
			"relation": "Employer",
			"targetSchema": "Company",
			"constraints": {
				"multiple": false
			}
		}
	}
}
