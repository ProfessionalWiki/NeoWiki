{
	"name": "ext.neowiki",
	"private": true,
	"version": "0.0.0",
	"license": "GPL-2.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"tsc:watch": "vue-tsc -b --watch",
		"vite:watch": "vite build --watch",
		"build:watch": "npm-run-all --parallel tsc:watch vite:watch",
		"lint:code": "eslint . --ext .vue,.ts --ignore-path .gitignore",
		"lint:styles": "NODE_NO_WARNINGS=1 stylelint \"src/**/*.{vue,less}\"",
		"lint": "npm-run-all lint:code lint:styles",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"test:watch": "vitest --coverage"
	},
	"devDependencies": {
		"@stylistic/eslint-plugin": "^3.1.0",
		"@types/jsdom": "^28.0.3",
		"@types/sortablejs": "^1.15.0",
		"@types/node": "^24.13.2",
		"@vitejs/plugin-vue": "^5.1.3",
		"@vitest/coverage-v8": "^2.1.1",
		"@vue/test-utils": "2.4.6",
		"@wikimedia/codex": "1.14.0",
		"@wikimedia/codex-design-tokens": "1.14.0",
		"@wikimedia/codex-icons": "1.14.0",
		"@wmde/eslint-config-wikimedia-typescript": "^0.2.14",
		"axios": "^1.18.1",
		"eslint": "^8.57.0",
		"eslint-config-wikimedia": "^0.32.4",
		"eslint-plugin-n": "^17.10.2",
		"eslint-plugin-unicorn": "^56.0.1",
		"jsdom": "^29.1.1",
		"less": "^4.6.7",
		"npm-run-all2": "^8.0.4",
		"pinia": "2.0.16",
		"postcss-html": "^1.7.0",
		"sortablejs": "^1.15.0",
		"stylelint": "^16.12.0",
		"stylelint-config-wikimedia": "^0.18.0",
		"types-mediawiki": "^2.0.0",
		"typescript": "^6.0.3",
		"vite": "^5.4.1",
		"vitest": "^2.1.1",
		"vue": "3.4.27",
		"vue-tsc": "^2.0.29"
	}
}
